generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Experience {
  id          String   @id @default(cuid())
  title       String   // Contoh: "RDK ITS 1446 H"
  role        String   // Contoh: "Ketua Pelaksana"
  category    String   // "Leadership", "Event", atau "Sosmas"
  year        String   // Contoh: "2024 - 2025"
  description String   @db.Text // Pake Text biar bisa nampung deskripsi panjang
  link        String?  // Optional (?) untuk link PDF sertifikat/bukti
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String   // Contoh: "Personal Portfolio Website"
  type        String   // Contoh: "Web App", "Data Science", dll
  description String?  @db.Text // Optional, buat deskripsi Masterpiece
  image       String?  // Optional, link gambar buat Masterpiece
  techStack   String[] // Array teks: ["Next.js", "Tailwind"] (Support di PostgreSQL!)
  link        String?  // Optional, link Live Preview atau Repo
  isFeatured  Boolean  @default(false) // True = Masterpiece (Atas), False = Arsip (Bawah)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Education {
  id          String   @id @default(cuid())
  institution String   // Contoh: "Institut Teknologi Sepuluh Nopember"
  major       String   // Contoh: "Sistem Informasi"
  degree      String   // Contoh: "Sarjana (S1)"
  year        String   // Contoh: "2022 - Sekarang"
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Shortlink {
  id        String   @id @default(cuid())
  slug      String   @unique // Kata kunci custom, misal: "cv", "linkedin", "rdk47"
  url       String   // URL asli yang panjang (tujuan redirect)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VisitorLog {
  id        String   @id @default(cuid())
  sessionId String   // Kunci unik dari Cookie (ID Khusus Pengunjung)
  path      String   // Halaman yang dibuka (misal: /cv, /shortlink)
  os        String?  // Sistem Operasi (Windows, Android, iOS)
  browser   String?  // Browser (Chrome, Safari, Firefox)
  device    String?  // Tipe Device (Mobile, Desktop, Tablet)
  referrer  String?  // Dateng dari mana (misal: instagram.com)
  createdAt DateTime @default(now())

  @@index([sessionId]) // Biar database lu cepet pas nyari jumlah "Unique Visitor"
}

model FinancialLog {
  id          String   @id @default(cuid())
  type        String   // "IN" atau "OUT"
  wallet      String   @default("CASH") // 👈 INI TAMBAHAN BARU
  amount      Int
  description String
  createdAt   DateTime @default(now())
}

model StockPortfolio {
  id                String   @id @default(cuid())
  emitenCode        String   // Kode saham: "BBCA", "TLKM", "BMRI", dll
  lotQuantity       Int      // Jumlah lot yang dimiliki (1 lot = 100 lembar untuk IDX)
  averageBuyPrice   Float    // Harga rata-rata pembelian per lembar (Rp)
  totalInvested     Float    // Total investasi = lotQuantity * 100 * averageBuyPrice
  currentPrice      Float?   // Harga saham saat ini (fetched dari API, optional)
  totalValue        Float?   // Nilai portofolio saat ini = lotQuantity * 100 * currentPrice
  gainLoss          Float?   // Profit/Loss = totalValue - totalInvested
  gainLossPercent   Float?   // Profit/Loss % = (gainLoss / totalInvested) * 100
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([emitenCode]) // Satu emiten hanya 1 record per portfolio
}
